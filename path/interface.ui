}

QPushButton {
	border: none;
}

QPushButton:hover {
	background-color: #1e90ff;
}

QComboBox {
	border: 1 px solid #ced4da;
	border-radius: 4px;
	padding-left: 10 px;
}

QComboBox::drop-down {
	border: 0px;
}

QComboBox::down-arrow {
	image: url(:/buttons/hide.svg);
	width:18px;
	height: 18px;
	margin-right: 10px;
}

QComboBox: on {
	border: 4px solid #c2dbfe
}

QComboBox QListView {
	font-size: 12px;
	border: 1px solid rgba(0,0,0,10%);
	padding: 5px;
	background-color: #fff;
	outline: 0px;
}

QComboBox QListView::item {
	padding-left: 10px;
	background-color: #fff;
}

QComboBox QListView::item:hover {
	background-color: #1e90ff;
}

QComboBox QListView::item:selected {
	background-color: #1e90ff;
}</string>
